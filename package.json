{
  "name": "llmflow",
  "version": "0.4.1",
  "description": "See what your LLM calls cost. One command. No signup.",
  "private": false,
  "type": "module",
  "bin": {
    "llmflow": "./bin/llmflow.js"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "bun run --filter @llmflow/server start",
    "start:verbose": "VERBOSE=1 bun run --filter @llmflow/server start",
    "dev": "bun run --filter @llmflow/server dev",
    "dev:server": "bun run --filter @llmflow/server dev",
    "dev:dashboard": "bun run --filter @llmflow/dashboard dev",
    "build": "bun run --filter @llmflow/dashboard build",
    "demo": "bun run --filter @llmflow/server demo",
    "demo:many": "bun run --filter @llmflow/server demo:many",
    "test": "bun run --filter @llmflow/server test",
    "test:otlp": "bun run --filter @llmflow/server test:otlp",
    "test:ws": "bun run --filter @llmflow/server test:ws",
    "test:logs": "bun run --filter @llmflow/server test:logs",
    "test:metrics": "bun run --filter @llmflow/server test:metrics",
    "test:providers": "bun run --filter @llmflow/server test:providers",
    "test:providers-e2e": "bun run --filter @llmflow/server test:providers-e2e",
    "test:e2e": "bunx playwright test",
    "test:e2e:headed": "bunx playwright test --headed",
    "test:e2e:ui": "bunx playwright test --ui",
    "typecheck": "bun run --filter '*' typecheck",
    "prepublishOnly": "bun install && bun run build"
  },
  "files": [
    "bin/",
    "apps/server/src/",
    "packages/*/src/",
    "packages/*/package.json",
    "packages/pricing/pricing.fallback.json",
    "public/"
  ],
  "keywords": [
    "llm",
    "observability",
    "tracing",
    "openai",
    "anthropic",
    "langchain",
    "opentelemetry",
    "cost-tracking",
    "ai",
    "bun"
  ],
  "author": "Helge Sverre",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HelgeSverre/llmflow"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/bun": "^1.3.5",
    "bun-types": "^1.3.5",
    "typescript": "^6.0.3"
  }
}
